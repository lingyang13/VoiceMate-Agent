*.ipch filter=lfs diff=lfs merge=lfs -text
*.db filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.vsidx filter=lfs diff=lfs merge=lfs -text
.vs/**/* filter=lfs diff=lfs merge=lfs -text

# 强制 C++ 为主语言
*.cpp linguist-language=C++
*.h linguist-language=C++
*.hpp linguist-language=C++
*.c linguist-language=C
*.cxx linguist-language=C++
*.cc linguist-language=C++

# 完全排除干扰语言（不参与统计）
*.py linguist-detectable=false
*.tcl linguist-detectable=false
*.l linguist-detectable=false
*.y linguist-detectable=false
*.lex linguist-detectable=false

# 标记为第三方/生成代码（完全忽略）
*.py linguist-vendored=true
*.tcl linguist-vendored=true
*.bin linguist-generated=true
*.model linguist-generated=true
*.onnx linguist-generated=true

# 文档类文件不计入统计
*.txt linguist-documentation=true
*.md linguist-documentation=true
*.json linguist-documentation=true
*.xml linguist-documentation=true
*.yml linguist-documentation=true
*.yaml linguist-documentation=true

# 忽略常见第三方目录
third_party/** linguist-vendored=true
vendor/** linguist-vendored=true
lib/** linguist-vendored=true
deps/** linguist-vendored=true
